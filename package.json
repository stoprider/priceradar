{
  "name": "priceradar-th",
  "version": "0.1.2",
  "private": true,
  "description": "Thai-first desktop and web price tracker for Thailand e-commerce",
  "author": "stoprider",
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "db:generate": "prisma generate",
    "db:push": "node scripts/sync-sqlite-schema.mjs",
    "db:seed": "tsx prisma/seed.ts",
    "scrape:mock": "tsx src/server/jobs/run-mock-check.ts",
    "prices:check": "tsx src/server/jobs/run-price-checks.ts",
    "desktop:dev": "concurrently -k \"npm:dev\" \"wait-on http://127.0.0.1:3000 && node scripts/run-electron-dev.mjs\"",
    "build:desktop": "npm run build && node scripts/prepare-desktop-bundle.mjs && electron-builder --win nsis",
    "postinstall": "prisma generate"
  },
  "build": {
    "appId": "th.priceradar.desktop",
    "productName": "PriceRadar TH",
    "asar": false,
    "directories": {
      "output": "dist-desktop"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "stoprider",
        "repo": "priceradar"
      }
    ],
    "files": [
      "electron/**/*",
      "desktop/bundle/**/*",
      "desktop/assets/**/*",
      "package.json"
    ],
    "win": {
      "icon": "src/app/favicon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "src/app/favicon.ico",
      "uninstallerIcon": "src/app/favicon.ico",
      "installerHeaderIcon": "src/app/favicon.ico",
      "artifactName": "PriceRadar TH Setup ${version}.${ext}"
    }
  },
  "dependencies": {
    "@prisma/client": "^6.16.0",
    "bcryptjs": "^3.0.3",
    "cheerio": "^1.2.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "jose": "^6.2.3",
    "lucide-react": "^1.17.0",
    "next": "16.2.9",
    "next-auth": "^4.24.14",
    "electron-updater": "^6.6.2",
    "node-cron": "^4.2.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "electron": "^37.0.0",
    "electron-builder": "^26.0.12",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.60.0",
    "prisma": "^6.16.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wait-on": "^9.0.1"
  }
}
